# CyberResilience360 — environment variables
# Copy to `.env` for local development. NEVER commit `.env`.
# In production (AWS), store all SECRET values in AWS Secrets Manager and
# inject them into the ECS task via secrets references — not as plain env vars.

# ---- Runtime ----
NODE_ENV=development
# Port the HTTP server binds to. AWS ALB / ECS will inject this automatically.
PORT=5000

# ---- Database (REQUIRED) ----
# PostgreSQL connection string used by Drizzle ORM + connect-pg-simple session store.
# AWS RDS PostgreSQL example (force TLS):
#   postgres://USER:PASSWORD@HOST:5432/cyres360?sslmode=require
DATABASE_URL=postgres://user:password@localhost:5432/cyres360

# ---- Sessions (REQUIRED IN PRODUCTION) ----
# Long random string (>= 64 chars). Server refuses to start in production if unset.
SESSION_SECRET=replace-with-long-random-string

# ---- Bootstrap admin (REQUIRED IN PRODUCTION on first boot) ----
# Used by server/seed.ts to provision the initial PLATFORM_ADMIN user.
# In production the server hard-fails on startup if these are missing.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password

# ---- HTTP host gating ----
# Production host the server will accept requests for. Other Host headers
# return 403, except the AWS health-check endpoint /health which is exempt.
ALLOWED_HOST=cyres360.toolsoftech.eu

# ---- Public app URL (for email links) ----
# Used to render absolute URLs in verification / password-reset emails.
APP_BASE_URL=https://cyres360.toolsoftech.eu

# ---- Replit-only (NOT used outside Replit, safe to omit on AWS) ----
# REPLIT_DEV_DOMAIN=
# REPLIT_DOMAINS=

# ---- Evidence / file storage backend ----
# Selects where uploaded evidence (PDFs, screenshots, exports) is persisted.
#   "local" (default)  — writes to ./uploads on the application disk
#                        (matches the legacy Replit deployment exactly).
#   "s3"               — writes to the configured S3 bucket using
#                        server-side encryption.
# Already-uploaded evidence keeps working after this flag is flipped, because
# read/delete code paths inspect the stored key prefix and select the right
# backend per row (uploads/* -> local, everything else -> s3).
FILE_STORAGE_PROVIDER=local

# Legacy alias accepted for backwards compatibility (older deployments
# may have set this). Prefer FILE_STORAGE_PROVIDER above.
# EVIDENCE_STORAGE_BACKEND=filesystem

# Maximum per-file upload size in MiB. Default 25.
MAX_UPLOAD_SIZE_MB=25

# ---- S3 evidence storage (REQUIRED when FILE_STORAGE_PROVIDER=s3) ----
# AWS region of the bucket. Defaults to eu-central-1 if unset.
AWS_REGION=eu-central-1
# Private S3 bucket holding evidence uploads. NEVER point this at a
# public bucket — the application enforces tenant access in code.
S3_EVIDENCE_BUCKET=
# Optional key prefix prepended to every new object key. Useful when sharing
# a bucket across environments (e.g. "cyberresilience360" or "staging").
S3_EVIDENCE_PREFIX=cyberresilience360
# Optional KMS key ARN/ID. When set, objects are written with SSE-KMS.
# When unset, objects are written with SSE-S3 (AES-256).
S3_KMS_KEY_ID=
# Presigned URL expiry in seconds (default 300 = 5 minutes). Currently only
# used by tooling — the in-app download route streams server-side so the
# existing auth + audit-log path applies uniformly.
S3_PRESIGNED_URL_EXPIRES_SECONDS=300
# AWS credentials are supplied by the ECS task role at runtime; no
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY env vars should be set on AWS.

# ---- Email provider (optional; configured in-app via Platform Settings) ----
# The platform stores SendGrid / Resend / SMTP credentials in the
# `platform_settings` database table and not in environment variables, so
# no SMTP secrets need to be set here. Configure them under
# Admin → Platform Settings → Email after the first boot.
